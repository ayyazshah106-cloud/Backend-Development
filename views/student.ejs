<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Document</title>
</head>

<body>
  <h1>hello</h1>
  <table border="1">
    <tr>
      <td>name</td>
      <td>Age</td>
      <td>Email</td>
    </tr>

    <% result.forEach(student=>{%>
      <tr>
        <td>
          <%=student.name %>
        </td>
        <td>
          <%=student.age %>
        </td>
        <td>
          <%=student.Email %>
        </td>

      </tr>

      <%})%>


  </table>
</body>

</html>